# Copy this file to public_html/midwaymusichall.net/api/.env on the server and fill in secrets.
APP_ENV=production
APP_DEBUG=false

# Database connection (GoDaddy phpMyAdmin)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=midway_music_hall
DB_USER=YOUR_DB_USER
DB_PASSWORD=CHANGE_ME
PAYPAL_SDK_CLIENT_ID=
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=REPLACE_WITH_SQUARE_ACCESS_TOKEN
SQUARE_LOCATION_ID=REPLACE_WITH_SQUARE_LOCATION_ID
SQUARE_CHECKOUT_REDIRECT_URL=https://midwaymusichall.net/payment/return
SQUARE_WEBHOOK_SIGNATURE_KEY=REPLACE_WITH_SQUARE_WEBHOOK_SIGNATURE_KEY
SQUARE_WEBHOOK_NOTIFICATION_URL=https://midwaymusichall.net/api/webhooks/square

# Upload directory (relative to php-backend/)
UPLOAD_DIR=uploads
APP_STORAGE_DIR=../storage
IMAGE_MANIFEST_DIR=../storage/image-manifests

# Session + security
ADMIN_SESSION_COOKIE=mmh_admin
ADMIN_SESSION_LIFETIME=604800
ADMIN_SESSION_IDLE_TIMEOUT=14400
ADMIN_SESSION_COOKIE_SECURE=true
ADMIN_LOGIN_THROTTLE_WINDOW_SECONDS=900
ADMIN_LOGIN_THROTTLE_MAX_FAILURES=10
ADMIN_LOGIN_THROTTLE_IP_MAX_FAILURES=30
JWT_SECRET=REPLACE_WITH_PRODUCTION_SECRET

# Email + routing (safe defaults: disabled)
SEND_EMAILS=false
SENDGRID_API_KEY=
STAFF_EMAIL_TO=midwayeventcenter@gmail.com
ALERTS_EMAIL_TO=support@jamarq.digital
BEACH_BANDS_EMAIL_TO=mmhbeachbands@gmail.com
EMAIL_FROM_NOTIFICATIONS=notifications@midwaymusichall.net
EMAIL_FROM_ALERTS=alerts@midwaymusichall.net

# CORS
CORS_ALLOW_ORIGINS=https://midwaymusichall.net,https://www.midwaymusichall.net

# Optional overrides
FORCE_STRICT_TRANSPORT=true
CSP_MODE=enforce
